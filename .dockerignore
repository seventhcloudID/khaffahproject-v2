# Ignore node_modules and build artifacts
node_modules
.next

# Ignore Docker and git files
Dockerfile
Dockerfile.*
docker-compose.yml
docker-compose.*.yml
.git
.gitignore

# Ignore local environment files and logs
.env.local
.env.*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore test script and assets
uat_script.py
*.png
*.pdf

